<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Feed - Mural de Likes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/feed">Mural de Likes</a>
            <div>
                <span class="navbar-text me-3">Olá, <%= user.username %>!</span>
                <a href="/posts/new" class="btn btn-primary">Nova Publicação</a>
                <form action="/logout" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-light">Sair</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div class="mb-4">
            <a href="/posts/new" class="btn btn-success">+ Criar Nova Publicação</a>
        </div>

        <% posts.forEach(post => { %>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">@<%= post.username %></h5>
                    <p class="card-text"><%= post.content %></p>
                    <% if (post.image_url) { %>
                        <img src="<%= post.image_url %>" class="img-fluid mb-3" alt="Imagem">
                    <% } %>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge bg-primary"><%= post.likes_count %> likes</span>
                        </div>
                        <div>
                            <% if (post.user_id === user.id) { %>
                                <form action="/posts/<%= post.id %>/delete" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Excluir?')">Excluir</button>
                                </form>
                            <% } else { %>
                                <form action="/posts/<%= post.id %>/like" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-primary btn-sm">Curtir</button>
                                </form>
                                <form action="/posts/<%= post.id %>/unlike" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Descurtir</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>

        <% if (posts.length === 0) { %>
            <p class="text-center">Nenhuma publicação ainda. Seja o primeiro!</p>
        <% } %>
    </div>
</body>
</html>